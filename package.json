{
  "name": "sazare-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spell-check": "cspell \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run --passWithNoTests",
    "build": "pnpm -r run build",
    "storybook": "storybook dev -p 6006",
    "storybook:restart": "lsof -ti:6006 | xargs kill -9 2>/dev/null; storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pandacss/dev": "^1.11.4",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "cspell": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "storybook": "^10.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "cspell --cache --no-summary --no-must-find-files"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
